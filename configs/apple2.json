{
  "$schema": "https://raw.githubusercontent.com/st3fan/ewm/main/schema/ewm-config.schema.json",
  "description": "Apple ][ — 48K, Integer BASIC, Disk II in slot 6, green monitor",
  "title": "Apple ][",
  "machine": {
    "model": "apple2",
    "rom": [
      { "address": "0xd000", "path": "builtin:341-0016" }, // Apple ][ Programmer's Aid #1, $D000-$D7FF
      { "address": "0xe000", "path": "builtin:341-0001" }, // Apple ][ Integer BASIC, $E000-$E7FF
      { "address": "0xe800", "path": "builtin:341-0002" }, // Apple ][ Integer BASIC, $E800-$EFFF
      { "address": "0xf000", "path": "builtin:341-0003" }, // Apple ][ Integer BASIC, $F000-$F7FF
      { "address": "0xf800", "path": "builtin:341-0004" }  // Apple ][ Original (non-autostart) Monitor, $F800-$FFFF
    ],
    "character_rom": "builtin:341-0036", // Apple ][ character ROM
    "slots": {
      "6": { "card": "diskii" }
    }
  },
  "display": { "monitor": "green" }
}
